#!/usr/bin/env bash

{{ template "sudo.tmpl" . }}
{{ template "pkg_install.tmpl" . }}

VIDEODEVICES=()
while IFS= read -r line; do
    VIDEODEVICES+=("$line")
done < <(lspci | grep -E "(VGA|3D|Display)")

NEEDS_NVIDIA_KMS=false

for device in "${VIDEODEVICES[@]}"; do
  if [[ $(echo "$device" | grep -i "nvidia") != "" ]]; then ### NVIDIA
    NEEDS_NVIDIA_KMS=true
    case "$(echo "$device" | grep -oP '[A-Z]{2}(?=[0-9]{3})' | head -n 1)" in 
    GP|GM|GK|GF|G[0-9]) ### OLD NVIDIA (LOWER THEN 16xx)
      pkg_install "nvidia-driver-580 nvidia-580xx-dkms nvidia-580xx-utils lib32-nvidia-580xx-utils vulkan-icd-loader lib32-vulkan-icd-loader"
      ;;
    *) 
      pkg_install "nvidia-open nvidia-utils lib32-nvidia-utils vulkan-icd-loader lib32-vulkan-icd-loader"
      ;;
    esac
  elif [[ $(echo "$device" | grep -i "radeon") != "" ]]; then ### AMD
    pkg_install "vulkan-radeon lib32-vulkan-radeon mesa-utils lib32-mesa"
  elif [[ $(echo "$device" | grep -i "intel") != "" ]]; then ### INTEL
    pkg_install "vulkan-intel lib32-vulkan-intel mesa-utils lib32-mesa"
  else
    pkg_install "mesa mesa-utils lib32-mesa"
  fi;
done

if [ "$NEEDS_NVIDIA_KMS" = true ]; then
    if command -v mkinitcpio &> /dev/null; then
        sudo sed -i 's/^MODULES=(.*/MODULES=(nvidia nvidia_modeset nvidia_uvm nvidia_drm)/' /etc/mkinitcpio.conf
        sudo mkinitcpio -P
    elif command -v update-initramfs &> /dev/null; then
        sudo update-initramfs -u -k all
    elif command -v dracut &> /dev/null; then
        echo 'force_drivers+=" nvidia nvidia_modeset nvidia_uvm nvidia_drm "' | sudo tee /etc/dracut.conf.d/nvidia.conf > /dev/null
        sudo dracut --force --regenerate-all 
    else
        echo "Warning: not found initramfs."
    fi
fi

